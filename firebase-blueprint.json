{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "avatar", "createdAt"]
    },
    "Tweet": {
      "title": "Tweet",
      "description": "A microblog post with media support",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["tweet", "retweet", "reply"] },
        "originalTweetId": { "type": "string" },
        "media": {
          "type": "object",
          "properties": {
            "youtubeId": { "type": "string" },
            "images": { "type": "array", "items": { "type": "string" } }
          }
        },
        "likesCount": { "type": "number" },
        "retweetsCount": { "type": "number" },
        "repliesCount": { "type": "number" },
        "impressions": { "type": "number" }
      },
      "required": ["authorId", "content", "timestamp", "type"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A reply to a tweet",
      "type": "object",
      "properties": {
        "tweetId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "parentId": { "type": "string" }
      },
      "required": ["tweetId", "authorId", "content", "timestamp"]
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Platform-wide growth metrics",
      "type": "object",
      "properties": {
        "dau": { "type": "number" },
        "mau": { "type": "number" },
        "totalTweets": { "type": "number" },
        "date": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user profiles"
    },
    "/tweets/{tweetId}": {
      "schema": "Tweet",
      "description": "Global public tweets"
    },
    "/tweets/{tweetId}/likes/{likeId}": {
      "schema": "Like",
      "description": "Individual likes on a tweet"
    },
    "/tweets/{tweetId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Threaded replies"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User-specific notifications"
    },
    "/analytics/{date}": {
      "schema": "Analytics",
      "description": "System metrics"
    }
  }
}
