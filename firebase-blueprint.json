{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "avatar", "createdAt"]
    },
    "Tweet": {
      "title": "Tweet",
      "description": "A microblog post with media support",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["tweet", "retweet", "reply"] },
        "originalTweetId": { "type": "string" },
        "media": {
          "type": "object",
          "properties": {
            "youtubeId": { "type": "string" },
            "images": { "type": "array", "items": { "type": "string" } }
          }
        },
        "likesCount": { "type": "number" },
        "retweetsCount": { "type": "number" },
        "repliesCount": { "type": "number" },
        "impressions": { "type": "number" }
      },
      "required": ["authorId", "content", "timestamp", "type"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A reply to a tweet",
      "type": "object",
      "properties": {
        "tweetId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "parentId": { "type": "string" }
      },
      "required": ["tweetId", "authorId", "content", "timestamp"]
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Platform-wide growth metrics",
      "type": "object",
      "properties": {
        "dau": { "type": "number" },
        "mau": { "type": "number" },
        "totalTweets": { "type": "number" },
        "date": { "type": "string" }
      }
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A private or group chat session",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastMessageSenderId": { "type": "string" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a conversation",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "video"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "readBy": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "User alert for social interactions",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["like", "comment", "retweet", "follow", "mention", "broadcast"] },
        "senderId": { "type": "string" },
        "relatedId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "content": { "type": "string" }
      }
    },
    "Follower": {
      "title": "Follower",
      "description": "Follow relationship between users",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followedId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user profiles"
    },
    "/tweets/{tweetId}": {
      "schema": "Tweet",
      "description": "Global public tweets"
    },
    "/tweets/{tweetId}/likes/{likeId}": {
      "schema": "Like",
      "description": "Individual likes on a tweet"
    },
    "/tweets/{tweetId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Threaded replies"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User-specific notifications"
    },
    "/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Messaging sessions"
    },
    "/conversations/{convId}/messages/{msgId}": {
      "schema": "Message",
      "description": "Messages within a session"
    },
    "/followers/{followId}": {
      "schema": "Follower",
      "description": "Follow graph"
    },
    "/analytics/{date}": {
      "schema": "Analytics",
      "description": "System metrics"
    }
  }
}
