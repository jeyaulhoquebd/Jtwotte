rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'jeyaulhoque2025@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'avatar', 'createdAt'])
        && data.keys().size() <= 8
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 50
        && data.email is string && data.email.size() <= 100
        && data.avatar is string && data.avatar.size() <= 500
        && (data.get('bio', '') is string && data.get('bio', '').size() <= 160)
        && (data.get('role', 'user') in ['user', 'admin'])
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) 
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().email == existing().email
        && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'bio', 'role']));
    }

    // --- Tweet Validation ---
    function isValidTweet(data) {
      return data.keys().hasAll(['authorId', 'content', 'timestamp', 'type'])
        && data.authorId == request.auth.uid
        && data.content is string && data.content.size() <= 1000
        && (data.get('media', null) == null || data.media is map)
        && data.timestamp == request.time
        && data.type in ['tweet', 'retweet', 'reply']
        && (data.get('originalTweetId', null) == null || isValidId(data.originalTweetId))
        && (data.get('likesCount', 0) is number)
        && (data.get('retweetsCount', 0) is number)
        && (data.get('repliesCount', 0) is number)
        && (data.get('impressions', 0) is number);
    }

    match /tweets/{tweetId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && isValidTweet(incoming());
      allow update: if isSignedIn() && (
        isAdmin()
        || (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'retweetsCount', 'repliesCount', 'impressions']))
        || (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'media']))
      );
      allow delete: if isSignedIn() && (isOwner(existing().authorId) || isAdmin());

      match /likes/{userId} {
        allow read: if true;
        allow create, delete: if isOwner(userId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isEmailVerified() && incoming().authorId == request.auth.uid;
        allow update, delete: if isOwner(existing().authorId) || isAdmin();
      }
    }

    match /analytics/{date} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /users/{userId}/notifications/{notiId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn(); // Social actions can trigger this
      allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    match /conversations/{convId} {
      allow read: if isSignedIn() && request.auth.uid in existing().participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && request.auth.uid in existing().participants
        && (incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt', 'lastMessageSenderId']));
      
      match /messages/{msgId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && incoming().senderId == request.auth.uid;
        allow update: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && incoming().diff(existing()).affectedKeys().hasOnly(['readBy']);
      }
    }

    match /followers/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().followerId == request.auth.uid;
      allow delete: if isSignedIn() && existing().followerId == request.auth.uid;
    }
  }
}
