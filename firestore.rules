rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.get('email', '') in ['jeyaulhoque2025@gmail.com', 'jeyaulbooks@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') in ['admin', 'founder'])
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'avatar', 'createdAt'])
        && data.keys().size() <= 15
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 64
        && data.email is string && data.email.size() <= 100
        && data.avatar is string && data.avatar.size() <= 1000000 
        && (data.get('role', 'user') in ['user', 'admin', 'founder'])
        && data.createdAt == request.time;
    }

    match /test/connection {
      allow get: if true;
    }

    match /users/{userId} {
      allow get, list: if true; 
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) 
        && incoming().get('uid', '') == existing().get('uid', '')
        && (
          isAdmin() || 
          (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'bio', 'cover', 'location', 'website', 'handle']))
        );
    }

    // --- Tweet Validation ---
    function isValidTweet(data) {
      return data.keys().hasAll(['authorId', 'content', 'timestamp', 'type'])
        && data.authorId == request.auth.uid
        && data.content is string && data.content.size() <= 10000
        && (data.timestamp == request.time || data.timestamp == existing().get('timestamp', request.time))
        && data.type in ['tweet', 'retweet', 'reply'];
    }

    match /tweets/{tweetId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidTweet(incoming());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().get('authorId', '')) && isValidTweet(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'media', 'type'])) ||
        // Interaction updates (likes, retweets, replies, impressions)
        incoming().diff(existing()).affectedKeys().hasAny(['likesCount', 'retweetsCount', 'repliesCount', 'impressions', 'reactions'])
      );
      allow delete: if isSignedIn() && (isOwner(existing().get('authorId', '')) || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && incoming().get('authorId', '') == request.auth.uid;
        allow update, delete: if isSignedIn() && (isOwner(existing().get('authorId', '')) || isAdmin());
      }
    }

    function isValidUserReaction(data) {
      return data.keys().hasAll(['userId', 'tweetId', 'type', 'createdAt'])
        && data.userId == request.auth.uid
        && data.get('tweetId', '') is string
        && data.type in ['like', 'love', 'insightful', 'fire', 'rocket']
        && (data.createdAt == request.time || data.createdAt == existing().get('createdAt', request.time));
    }

    match /user_reactions/{reactionId} {
      allow list: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidUserReaction(incoming());
      allow update: if isSignedIn() && (isOwner(existing().get('userId', '')) || isAdmin()) && isValidUserReaction(incoming());
      allow delete: if isSignedIn() && (isOwner(existing().get('userId', '')) || isAdmin());
    }

    match /followers/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().get('followerId', '') == request.auth.uid;
      allow delete: if isSignedIn() && (existing().get('followerId', '') == request.auth.uid || isAdmin());
    }

    match /analytics/{date} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notiId} {
      allow list: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow create: if isSignedIn(); 
      allow update, delete: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
    }

    match /bookmarks/{bookmarkId} {
      allow read: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().get('userId', '') == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
    }

    match /conversations/{convId} {
      allow read: if isSignedIn() && (existing() == null || request.auth.uid in existing().participants || isAdmin());
      allow create: if isSignedIn() && (request.auth.uid in incoming().participants || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid in existing().participants || isAdmin());
      
      match /messages/{msgId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants || isAdmin());
        allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
        allow update: if isSignedIn() && (isOwner(existing().senderId) || isAdmin());
        allow delete: if isSignedIn() && (isOwner(existing().senderId) || isAdmin());
      }
    }
  }
}
