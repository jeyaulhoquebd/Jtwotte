rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'jeyaulhoque2025@gmail.com' ||
        request.auth.token.email == 'jeyaulbooks@gmail.com'
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'avatar', 'createdAt'])
        && data.keys().size() <= 12
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 64
        && data.email is string && data.email.size() <= 100
        && data.avatar is string && data.avatar.size() <= 1000000 // Allow dataURL
        && (data.get('cover', '') is string && data.get('cover', '').size() <= 1000000)
        && (data.get('bio', '') is string && data.get('bio', '').size() <= 500)
        && (data.get('location', '') is string && data.get('location', '').size() <= 100)
        && (data.get('website', '') is string && data.get('website', '').size() <= 200)
        && (data.get('role', 'user') in ['user', 'admin', 'founder'])
        && data.createdAt == request.time;
    }

    match /test/connection {
      allow get: if true;
    }

    match /users/{userId} {
      allow read: if true; 
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) 
        && incoming().uid == existing().uid
        && (
          (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'bio', 'role', 'cover', 'location', 'website']))
          || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'bio', 'cover', 'location', 'website']))
        );
    }

    // --- Tweet Validation ---
    function isValidTweet(data) {
      return data.keys().hasAll(['authorId', 'content', 'timestamp', 'type'])
        && data.authorId == request.auth.uid
        && data.content is string && data.content.size() <= 5000
        && data.timestamp == request.time
        && data.type in ['tweet', 'retweet', 'reply'];
    }

    match /tweets/{tweetId} {
      allow read: if true;
      allow create: if isSignedIn()
        && isValidTweet(incoming());
      allow update: if isSignedIn(); // Allow likes, counts, impressions from anyone, and edits from owner/admin
      allow delete: if isSignedIn() && (isOwner(existing().authorId) || isAdmin());

      match /likes/{userId} {
        allow read: if true;
        allow create, delete: if isOwner(userId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
        allow update, delete: if isOwner(existing().authorId) || isAdmin();
      }
    }

    match /analytics/{date} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/notifications/{notiId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /conversations/{convId} {
      allow read: if isSignedIn() && (existing() == null || request.auth.uid in existing().participants);
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && request.auth.uid in existing().participants;
      
      match /messages/{msgId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
        allow update: if isSignedIn();
      }
    }

    match /followers/{followId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}
