rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'avatar', 'createdAt'])
        && data.keys().size() <= 7
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 50
        && data.email is string && data.email.size() <= 100
        && data.avatar is string && data.avatar.size() <= 500
        && (data.get('bio', '') is string && data.get('bio', '').size() <= 160)
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().email == existing().email
        && incoming().keys().hasAll(['uid', 'name', 'email', 'avatar', 'createdAt'])
        && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'bio']));
    }

    // --- Tweet Validation ---
    function isValidTweet(data) {
      return data.keys().hasAll(['authorId', 'content', 'timestamp', 'type'])
        && data.authorId == request.auth.uid
        && data.content is string && data.content.size() > 0 && data.content.size() <= 280
        && data.timestamp == request.time
        && data.type in ['tweet', 'retweet']
        && (data.get('originalTweetId', null) == null || isValidId(data.originalTweetId));
    }

    match /tweets/{tweetId} {
      allow read: if true;
      allow create: if isSignedIn() && isEmailVerified() && isValidUser(get(/databases/$(database)/documents/users/$(request.auth.uid)).data) && isValidTweet(incoming());
      allow update: if isSignedIn() && (
        // System update: Increments (like, retweet, reply) - Actually usually done via subcollections or server
        // But for simplicity in a client-side demo we might allow specific count increments
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'retweetsCount', 'repliesCount']))
        || (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content']))
      );
      allow delete: if isSignedIn() && isOwner(existing().authorId);

      match /likes/{userId} {
        allow read: if true;
        allow create, delete: if isOwner(userId);
      }
    }

    match /users/{userId}/notifications/{notiId} {
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
  }
}
